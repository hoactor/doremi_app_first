# DoReMiSsul Studio - 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 키를 입력하세요
# cp .env.example .env

# Gemini API Key (이미지 생성용) - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Claude API Key (대본 분석/프롬프트 생성용) - https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# Supertone API Key (TTS 음성합성용)
SUPERTONE_API_KEY=your_supertone_api_key_here
